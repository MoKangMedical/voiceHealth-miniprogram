/* app.wxss - VoiceHealth Global Styles */
page {
  background: #0a0a0f;
  color: #e2e2e8;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 0 32rpx;
}

/* Colors */
.text-primary { color: #3b82f6; }
.text-green { color: #22c55e; }
.text-yellow { color: #eab308; }
.text-red { color: #ef4444; }
.text-dim { color: rgba(255,255,255,0.45); }
.text-muted { color: rgba(255,255,255,0.25); }
.bg-card { background: rgba(255,255,255,0.04); }

/* Cards */
.card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

/* Buttons */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #3b82f6;
  color: #fff;
}

.btn-primary:active {
  background: #2563eb;
}

.btn-ghost {
  background: rgba(255,255,255,0.04);
  color: #e2e2e8;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.btn-pay {
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: #fff;
}

/* Badges */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-green { background: rgba(34,197,94,0.15); color: #22c55e; }
.badge-yellow { background: rgba(234,179,8,0.15); color: #eab308; }
.badge-red { background: rgba(239,68,68,0.15); color: #ef4444; }

/* Section */
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.45);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin: 40rpx 0 20rpx;
}

/* Disclaimer */
.disclaimer {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
  text-align: center;
  padding: 20rpx 40rpx;
  line-height: 1.6;
}

/* Animation */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.5s ease forwards;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(59,130,246,0.2);
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 20rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  text-align: center;
}

/* Progress Bar */
.progress-bar {
  height: 12rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-fill.green { background: #22c55e; }
.progress-fill.blue { background: #3b82f6; }
.progress-fill.yellow { background: #eab308; }
.progress-fill.red { background: #ef4444; }

/* Divider */
.divider {
  height: 1rpx;
  background: rgba(255,255,255,0.06);
  margin: 24rpx 0;
}

/* Tag */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.65);
}
