/* pages/history/history.wxss */
.container {
  padding: 0 32rpx 40rpx;
  min-height: 100vh;
}

.page-header {
  padding: 48rpx 0 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
  gap: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(59,130,246,0.2);
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

/* Records List */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  transition: all 0.3s ease;
}

.record-item:active {
  transform: scale(0.98);
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.record-score {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.score-num {
  font-size: 48rpx;
  font-weight: 700;
}

.score-unit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

.record-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

.record-summary {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-duration {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
}

.record-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  background: none;
  border: none;
  padding: 8rpx;
  margin: 0;
  line-height: 1;
}

.action-btn::after {
  display: none;
}

.action-icon {
  font-size: 32rpx;
}

/* Load More */
.load-more, .no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.25);
}

.load-more {
  color: #3b82f6;
}
