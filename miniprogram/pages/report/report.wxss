/* pages/report/report.wxss */
.container {
  padding: 0 32rpx 40rpx;
  min-height: 100vh;
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid rgba(59,130,246,0.2);
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
}

/* Error State */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.error-icon {
  font-size: 80rpx;
}

.error-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
}

/* Report Header */
.report-header {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.report-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  margin-bottom: 40rpx;
}

.report-score {
  display: flex;
  justify-content: center;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid #3b82f6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 56rpx;
  font-weight: 700;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 8rpx;
}

/* Cards */
.card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* Summary */
.summary-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: rgba(255,255,255,0.85);
}

/* Features */
.feature-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.feature-row:last-child {
  margin-bottom: 0;
}

.feature-name {
  width: 120rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
}

.feature-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 6rpx;
  overflow: hidden;
}

.feature-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

.feature-value {
  width: 80rpx;
  font-size: 24rpx;
  text-align: right;
  color: rgba(255,255,255,0.65);
}

/* Risks */
.risk-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.risk-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.risk-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.risk-name {
  font-size: 28rpx;
  font-weight: 500;
}

.risk-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.risk-suggestion {
  background: rgba(59,130,246,0.08);
  border-radius: 16rpx;
  padding: 20rpx;
}

.suggestion-label {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 500;
}

.suggestion-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
}

/* Insight */
.insight-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: rgba(255,255,255,0.85);
}

/* Disclaimer */
.disclaimer {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
  text-align: center;
  padding: 32rpx 20rpx;
  line-height: 1.6;
}

/* Actions */
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.actions .btn {
  flex: 1;
}
