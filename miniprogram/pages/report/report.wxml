<!--pages/report/report.wxml-->
<view class="container">
  <!-- Loading -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载报告...</text>
  </view>

  <!-- Error -->
  <view class="error-state" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="btn btn-primary" bindtap="goHome">返回首页</button>
  </view>

  <!-- Report Content -->
  <view class="report-content" wx:else>
    <!-- Header -->
    <view class="report-header">
      <view class="report-title">健康参考报告</view>
      <view class="report-time">{{report.createTime}}</view>
      <view class="report-score">
        <view class="score-circle" style="border-color: {{report.overallColor}}">
          <text class="score-value">{{report.overallScore}}</text>
          <text class="score-label">综合评分</text>
        </view>
      </view>
    </view>

    <!-- Overall Summary -->
    <view class="card summary-card">
      <view class="card-title">总体评估</view>
      <view class="summary-text">{{report.summary}}</view>
    </view>

    <!-- Acoustic Features -->
    <view class="section-title">声学特征分析</view>
    <view class="card features-card">
      <view class="feature-row" wx:for="{{report.features}}" wx:key="name">
        <view class="feature-name">{{item.name}}</view>
        <view class="feature-bar">
          <view class="feature-fill" style="width: {{item.percent}}%; background: {{item.color}}"></view>
        </view>
        <view class="feature-value">{{item.value}}</view>
      </view>
    </view>

    <!-- Risk Items -->
    <view class="section-title">健康维度参考</view>
    <view class="card risks-card">
      <view class="risk-item" wx:for="{{report.risks}}" wx:key="name">
        <view class="risk-header">
          <text class="risk-name">{{item.name}}</text>
          <view class="badge badge-{{item.level}}">{{item.levelText}}</view>
        </view>
        <view class="risk-desc">{{item.description}}</view>
        <view class="risk-suggestion" wx:if="{{item.suggestion}}">
          <text class="suggestion-label">建议：</text>
          <text class="suggestion-text">{{item.suggestion}}</text>
        </view>
      </view>
    </view>

    <!-- AI Insight -->
    <view class="section-title">AI健康洞察</view>
    <view class="card insight-card">
      <view class="insight-text">{{report.insight}}</view>
    </view>

    <!-- Disclaimer -->
    <view class="disclaimer">
      * 本报告由AI生成，仅供参考，不构成医疗建议。如有健康问题，请咨询专业医生。
    </view>

    <!-- Actions -->
    <view class="actions">
      <button class="btn btn-ghost" bindtap="saveReportImage">保存报告</button>
      <button class="btn btn-primary" bindtap="goHome">重新检测</button>
    </view>
  </view>
</view>
