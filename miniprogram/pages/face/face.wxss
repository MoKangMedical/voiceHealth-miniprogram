/* pages/face/face.wxss */
.container {
  padding: 0 32rpx 40rpx;
  min-height: 100vh;
}

.page-header {
  padding: 48rpx 0 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

/* Camera Section */
.camera-section {
  margin-bottom: 32rpx;
}

.camera {
  width: 100%;
  height: 800rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.camera-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.face-guide {
  width: 400rpx;
  height: 500rpx;
  border: 4rpx solid rgba(255,255,255,0.6);
  border-radius: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 40rpx;
}

.guide-circle {
  width: 100%;
  height: 100%;
  border-radius: 200rpx;
  border: 4rpx solid rgba(255,255,255,0.6);
}

.guide-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 20rpx;
}

.camera-actions {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-top: 32rpx;
}

.btn-capture {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 0;
}

.capture-icon {
  font-size: 48rpx;
}

/* Preview Section */
.preview-section {
  margin-bottom: 32rpx;
}

.photo-preview {
  width: 100%;
  height: 800rpx;
  border-radius: 28rpx;
}

.preview-tips {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(34,197,94,0.1);
  border-radius: 12rpx;
}

.tip-icon {
  color: #22c55e;
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
}

/* Initial Section */
.initial-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.initial-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.initial-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.initial-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
  margin-bottom: 48rpx;
}

.initial-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.initial-tips {
  width: 100%;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  color: #3b82f6;
  font-size: 28rpx;
}

/* Analyze Section */
.analyze-section {
  margin-bottom: 32rpx;
}

.free-info {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
}

/* Result Section */
.score-card {
  background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(59,130,246,0.1));
  border: 1rpx solid rgba(139,92,246,0.3);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.score-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.score-title {
  font-size: 32rpx;
  font-weight: 600;
}

.score-main {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 8rpx solid #8b5cf6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.score-info {
  flex: 1;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* Dimensions */
.dimensions-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.dimension-item {
  margin-bottom: 28rpx;
}

.dimension-item:last-child {
  margin-bottom: 0;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dim-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dim-icon {
  font-size: 28rpx;
}

.dim-name {
  font-size: 28rpx;
  font-weight: 500;
}

.dim-score {
  font-size: 28rpx;
  font-weight: 600;
  color: #8b5cf6;
}

.dim-bar {
  height: 12rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.dim-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

.dim-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

/* Suggestions */
.suggestions-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.suggestion-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.suggestion-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.suggestion-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.suggestion-icon {
  font-size: 28rpx;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 500;
}

.suggestion-content {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.7;
}

/* Actions */
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.actions .btn {
  flex: 1;
}

/* Disclaimer */
.disclaimer {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
  text-align: center;
  padding: 40rpx 20rpx;
  line-height: 1.6;
}
