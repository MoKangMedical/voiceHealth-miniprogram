/* pages/combined/combined.wxss */
.container {
  padding: 0 32rpx 40rpx;
  min-height: 100vh;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid rgba(139,92,246,0.2);
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
}

.page-header {
  padding: 48rpx 0 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
}

/* Score Card */
.score-card {
  background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(59,130,246,0.1));
  border: 1rpx solid rgba(139,92,246,0.3);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.score-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.data-sources {
  display: flex;
  gap: 12rpx;
}

.source-item {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 20rpx;
}

.score-main {
  display: flex;
  justify-content: center;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid #8b5cf6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 56rpx;
  font-weight: 700;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 8rpx;
}

/* Age Card */
.age-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.age-main {
  text-align: center;
  margin-bottom: 32rpx;
}

.age-predicted {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.age-value {
  font-size: 72rpx;
  font-weight: 700;
}

.age-unit {
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
}

.age-diff {
  font-size: 26rpx;
  margin-top: 12rpx;
}

.age-diff.younger {
  color: #22c55e;
}

.age-diff.older {
  color: #ef4444;
}

.age-details {
  display: flex;
  gap: 20rpx;
}

.age-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx;
  background: rgba(59,130,246,0.08);
  border-radius: 16rpx;
}

.age-icon {
  font-size: 32rpx;
}

.age-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.age-val {
  font-size: 28rpx;
  font-weight: 600;
}

/* Section Title */
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.45);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin: 40rpx 0 20rpx;
}

/* Dimensions Card */
.dimensions-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.dimension-item {
  margin-bottom: 24rpx;
}

.dimension-item:last-child {
  margin-bottom: 0;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dim-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dim-icon {
  font-size: 28rpx;
}

.dim-name {
  font-size: 28rpx;
  font-weight: 500;
}

.dim-score {
  font-size: 32rpx;
  font-weight: 600;
}

.dim-bar {
  height: 12rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 6rpx;
  overflow: hidden;
}

.dim-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

/* Detail Card */
.detail-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.detail-summary {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.detail-features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.feature-name {
  width: 100rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
}

.feature-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 6rpx;
  overflow: hidden;
}

.feature-fill {
  height: 100%;
  border-radius: 6rpx;
}

.feature-value {
  width: 100rpx;
  font-size: 24rpx;
  text-align: right;
  color: rgba(255,255,255,0.65);
}

/* Face Dimensions */
.face-dimensions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.face-dim-item {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.face-dim-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.face-dim-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.face-dim-icon {
  font-size: 24rpx;
}

.face-dim-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
}

.face-dim-score {
  font-size: 28rpx;
  font-weight: 600;
  color: #8b5cf6;
}

.face-dim-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  padding-left: 36rpx;
}

/* Suggestions Card */
.suggestions-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.suggestion-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.suggestion-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.suggestion-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.suggestion-icon {
  font-size: 28rpx;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 500;
}

.suggestion-content {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.7;
}

/* Disclaimer */
.disclaimer {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
  text-align: center;
  padding: 40rpx 20rpx;
  line-height: 1.6;
}

/* Actions */
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.actions .btn {
  flex: 1;
}
