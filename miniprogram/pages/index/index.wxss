/* pages/index/index.wxss */
.container {
  padding: 0 32rpx 40rpx;
  min-height: 100vh;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 20rpx;
}

.logo {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-icon {
  font-size: 48rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.1);
}

/* Main Card */
.main-card {
  background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(34,197,94,0.06));
  border: 1rpx solid rgba(59,130,246,0.15);
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  margin: 32rpx 0;
  text-align: center;
}

.card-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.card-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  margin-bottom: 48rpx;
}

/* Record Button */
.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.record-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(59,130,246,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.record-btn.recording {
  background: rgba(239,68,68,0.2);
}

.record-btn-inner {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #3b82f6;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.record-btn.recording .record-btn-inner {
  background: #ef4444;
}

.record-icon {
  font-size: 64rpx;
}

.record-ripple {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid rgba(239,68,68,0.3);
  animation: ripple 1.5s infinite;
}

@keyframes ripple {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

.record-time {
  font-size: 48rpx;
  font-weight: 300;
  margin: 24rpx 0 8rpx;
  font-variant-numeric: tabular-nums;
}

.record-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

/* Analyze Button */
.btn-analyze {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.btn-analyze[disabled] {
  background: rgba(59,130,246,0.3);
  color: rgba(255,255,255,0.3);
}

.free-info {
  font-size: 24rpx;
}

/* Features Grid */
.features-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.feature-item {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  font-size: 48rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
}

.feature-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

/* Tips */
.tips-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 32rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  color: #3b82f6;
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
}

/* Disclaimer */
.disclaimer {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
  text-align: center;
  padding: 40rpx 20rpx;
  line-height: 1.6;
}
