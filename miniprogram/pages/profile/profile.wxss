/* pages/profile/profile.wxss */
.container {
  padding: 0 32rpx 40rpx;
  min-height: 100vh;
}

/* User Section */
.user-section {
  padding: 48rpx 0 32rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.1);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.user-badge {
  display: flex;
  gap: 12rpx;
}

/* Login Card */
.login-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
}

.login-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-icon {
  font-size: 60rpx;
}

.login-info {
  flex: 1;
}

.login-text {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.login-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

/* Stats Section */
.stats-section {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.06);
}

/* VIP Card */
.vip-card {
  background: linear-gradient(135deg, rgba(234,179,8,0.15), rgba(249,115,22,0.1));
  border: 1rpx solid rgba(234,179,8,0.3);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.vip-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.vip-icon {
  font-size: 48rpx;
}

.vip-info {
  flex: 1;
}

.vip-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.vip-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
}

.vip-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #eab308;
}

/* Menu Section */
.menu-section {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 28rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255,255,255,0.02);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.menu-info {
  display: flex;
  flex-direction: column;
}

.menu-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
}

.menu-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.25);
}

/* Footer */
.footer {
  text-align: center;
  padding: 48rpx 0;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
  margin-bottom: 8rpx;
}
